# ── RPC / Network ───────────────────────────────────────────────────────────
# Alchemy or Infura WebSocket endpoint for event listening (wss://)
RPC_URL=wss://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ── Backend Signer ──────────────────────────────────────────────────────────
# Private key of the wallet that holds BACKEND_ROLE in CarbonCreditToken
# NEVER commit this to git. Use a secret manager in production.
BACKEND_PRIVATE_KEY=0xYOUR_BACKEND_PRIVATE_KEY

# ── Contract Addresses (fill after deploy) ──────────────────────────────────
CARBON_CREDIT_TOKEN_ADDRESS=0x...
MARKETPLACE_ADDRESS=0x...

# ── Server ──────────────────────────────────────────────────────────────────
PORT=4000
