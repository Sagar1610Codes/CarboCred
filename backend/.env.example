# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/carbon_credit_platform

# Authentication
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Blockchain
RPC_URL=https://rpc-amoy.polygon.technology
PRIVATE_KEY=your_wallet_private_key_never_commit_this
CONTRACT_ADDRESS=0xYourCarbonCreditContractAddress

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# Blockchain Settings
BLOCK_CONFIRMATIONS=2
EVENT_POLL_INTERVAL_MS=15000
START_BLOCK=0
