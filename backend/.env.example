# ── RPC / Network ───────────────────────────────────────────────────────────
# Alchemy or Infura WebSocket endpoint for event listening (wss://)
RPC_URL=wss://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ── Backend Signer ──────────────────────────────────────────────────────────
# Private key of the wallet that holds BACKEND_ROLE in CarbonCreditToken
# NEVER commit this to git. Use a secret manager in production.
BACKEND_PRIVATE_KEY=0xYOUR_BACKEND_PRIVATE_KEY

# ── Contract Addresses (fill after deploy) ──────────────────────────────────
CARBON_CREDIT_TOKEN_ADDRESS=0x...
MARKETPLACE_ADDRESS=0x...

# ── Server ──────────────────────────────────────────────────────────────────
PORT=4000

# ── Auth ─────────────────────────────────────────────────────────────────────
# A long random string used to sign JWTs.  Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET

# Secret key required to register accounts with role ADMIN.
# Pass { adminSeedKey: "<this value>" } in POST /auth/register body.
# Remove or leave blank after seeding your admin account(s) to prevent new ones.
ADMIN_SEED_KEY=REPLACE_WITH_ANOTHER_SECRET
