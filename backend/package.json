{
    "name": "carbon-credit-platform-backend",
    "version": "1.0.0",
    "description": "Production-grade Node.js backend for Blockchain-Enabled Carbon Credit Issuance, Trading & Transparency Platform",
    "type": "module",
    "main": "src/server.js",
    "engines": {
        "node": ">=18.0.0"
    },
    "scripts": {
        "dev": "nodemon --experimental-specifier-resolution=node src/server.js",
        "start": "node --experimental-specifier-resolution=node src/server.js",
        "lint": "eslint src --ext .js",
        "lint:fix": "eslint src --ext .js --fix",
        "format": "prettier --write \"src/**/*.js\"",
        "prepare": "husky install"
    },
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "ethers": "^6.11.1",
        "express": "^4.18.3",
        "express-rate-limit": "^7.2.0",
        "helmet": "^7.1.0",
        "joi": "^17.12.2",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.2.1",
        "pino": "^8.19.0",
        "pino-pretty": "^11.0.0",
        "winston": "^3.12.0"
    },
    "devDependencies": {
        "@commitlint/cli": "^19.2.1",
        "@commitlint/config-conventional": "^19.1.0",
        "eslint": "^8.57.0",
        "eslint-plugin-import": "^2.29.1",
        "husky": "^9.0.11",
        "lint-staged": "^15.2.2",
        "nodemon": "^3.1.0",
        "prettier": "^3.2.5"
    },
    "lint-staged": {
        "src/**/*.js": [
            "eslint --fix",
            "prettier --write"
        ]
    }
}