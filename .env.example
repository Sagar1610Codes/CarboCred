# ── Hardhat / Deployment ────────────────────────────────────────────────────
# Private key of the deployer wallet (no 0x prefix needed by some tools, keep consistent)
DEPLOYER_PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY

# RPC endpoint for Sepolia testnet (Alchemy or Infura)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Etherscan API key for contract verification
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# ── Deployed Contract Addresses (fill after deploy) ─────────────────────────
ENTITY_REGISTRY_ADDRESS=0x...
MARKETPLACE_ADDRESS=0x...
